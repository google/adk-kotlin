<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.google.adk.kt.examples.android">

    <uses-permission android:name="com.google.android.apps.aicore.service.BIND_SERVICE" />
    <!-- Required by the Firebase-backed examples (Skills, Firebase AI): they talk to the cloud
         Firebase AI (Gemini) backend. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="ADK Android Examples"
        android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">

        <!-- The launcher: a menu that opens each self-contained example. -->
        <activity
            android:name=".home.HomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Examples, launched from HomeActivity via explicit intent (no launcher entry of their
             own, so not exported). -->
        <!--
            configChanges: keep the running activity (and its in-memory transcript, agent session,
            and any in-flight coroutines) alive across rotation, instead of being destroyed and
            recreated. This is only appropriate because these screens build their UI in code with no
            configuration-specific resources to reload. A real-world app would instead let the
            activity recreate and hold this state in a ViewModel (which survives configuration
            changes), plus SavedStateHandle / onSaveInstanceState to also survive process death. We
            keep it simple here and skip the ViewModel.
        -->
        <activity
            android:name=".roomsession.RoomSessionActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".skillsassetsource.SkillsAssetSourceActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".mlkitchat.MlKitChatActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!--
            Fallback Firebase configuration for the Firebase-backed examples (Skills, Firebase AI),
            used only when this APK is built WITHOUT a google-services.json (the standard path).
            These values are baked in at build time from the FIREBASE_* manifest placeholders (see
            examples/android/build.gradle.kts), sourced from Gradle properties or environment
            variables. When google-services.json is present the default FirebaseApp is initialized
            from it and these entries are ignored. See examples/android/README.md.
        -->
        <meta-data
            android:name="com.google.adk.FIREBASE_API_KEY"
            android:value="${FIREBASE_API_KEY}" />
        <meta-data
            android:name="com.google.adk.FIREBASE_APP_ID"
            android:value="${FIREBASE_APP_ID}" />
        <meta-data
            android:name="com.google.adk.FIREBASE_PROJECT_ID"
            android:value="${FIREBASE_PROJECT_ID}" />
        <activity
            android:name=".firebase.FirebaseChatActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
    </application>
</manifest>
